# Optional: remote JSON source URL. If set, this takes precedence.
# TREND_DATA_URL=https://example.com/trend_tables.json

# Optional: local JSON path for development (relative to project root or absolute path).
# If not set, app uses: public/trend_tables.json
# TREND_JSON_PATH=excel_output/trend_tables.json

# Optional: site URL for server-side fetch in production.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Required for Supabase authentication.
# Create a project in Supabase and copy from Project Settings -> API.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
